{
  "name": "@ghar-kharcha/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ghar-kharcha/shared-types": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.6.20",
    "jose": "^5.9.6",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/pdf-parse": "^1.1.4",
    "drizzle-kit": "^0.30.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
